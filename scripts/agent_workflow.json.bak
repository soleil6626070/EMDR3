      "event_to_image": {
        "source": "event_node",
        "target": "image_node",
        "forward_condition": {
          "label": null,
          "type": "llm",
          "condition": "The client has named a specific event, memory, or incident they want to work with (not just a vague topic like 'my childhood' — a particular moment or situation)."
        },
        "backward_condition": null
      },
      "image_to_neg_cog": {
        "source": "image_node",
        "target": "neg_cog_node",
        "forward_condition": {
          "label": null,
          "type": "llm",
          "condition": "The client has identified a single freeze-frame image representing the worst part of the experience, OR has confirmed they do not think in images and is just holding the incident in mind."
        },
        "backward_condition": null
      },
      "neg_cog_to_pos_cog": {
        "source": "neg_cog_node",
        "target": "pos_cog_node",
        "forward_condition": {
          "label": null,
          "type": "llm",
          "condition": "The client has stated a valid negative cognition: a self-referential present-tense belief about themselves (e.g. 'I am powerless', 'I am unsafe', 'There is something wrong with me'). NOT a factual description ('I was attacked'), NOT a bare emotion ('I am afraid'), NOT specific to the event ('I failed that test')."
        },
        "backward_condition": null
      },
      "pos_cog_to_voc": {
        "source": "pos_cog_node",
        "target": "voc_node",
        "forward_condition": {
          "label": null,
          "type": "llm",
          "condition": "The client has stated a valid positive cognition: a self-referential present-tense belief on the same theme as the negative cognition, plausibly believable, and ideally not phrased with 'not'/'never'/'always' (e.g. 'I am strong now', 'I am safe', 'I can succeed', 'I am worthy of love')."
        },
        "backward_condition": null
      },
      "voc_to_emotion": {
        "source": "voc_node",
        "target": "emotion_node",
        "forward_condition": {
          "label": null,
          "type": "llm",
          "condition": "The client has given a single VOC number between 1 and 7."
        },
        "backward_condition": null
      },
      "emotion_to_sud": {
        "source": "emotion_node",
        "target": "sud_node",
        "forward_condition": {
          "label": null,
          "type": "llm",
          "condition": "The client has named at least one specific emotion (e.g. sadness, anger, fear, shame, guilt, grief) — not a vague descriptor like 'bad'."
        },
        "backward_condition": null
      },
      "sud_to_body": {
        "source": "sud_node",
        "target": "body_node",
        "forward_condition": {
          "label": null,
          "type": "llm",
          "condition": "The client has given a single SUD number between 0 and 10."
        },
        "backward_condition": null
      },
      "body_to_end": {
        "source": "body_node",
        "target": "end_node",
        "forward_condition": {
          "label": null,
          "type": "llm",
          "condition": "The client has identified a body location for the disturbance (or has confirmed after coaching that they cannot access one), AND the agent has thanked them and indicated the assessment is complete."
        },
        "backward_condition": null
      },
      "edge_01ksfvf3rbeh0v7kweeyy1p2cq": {
        "source": "event_node",
        "target": "node_01ksfr00creh0v7kvpxfrrk37t",
        "forward_condition": {
          "label": "unable to pick specific event",
