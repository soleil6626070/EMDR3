          "x": -274.324844768272,
          "y": 540.9860492037965
        },
        "edge_order": [
          "sud_to_body"
        ],
        "label": "SUD Rating (0–10)",
        "auto_advance_after_first_response": false
      },
      "body_node": {
        "conversation_config": {
          "turn": {
            "turn_eagerness": "patient",
            "spelling_patience": null,
