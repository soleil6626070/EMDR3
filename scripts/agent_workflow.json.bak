              "built_in_tools": {}
            }
          }
        },
        "additional_prompt": "STAGE: Orient the client.\n\nBriefly (in 1–2 sentences) explain: 'We're going to work together to identify a target image. This doesn't mean recalling the whole event — just a snapshot of the worst moment.' Ask if they're ready to begin.\n\nAdvance to the next stage as soon as the client indicates they're ready.",
        "additional_knowledge_base": [],
        "additional_tool_ids": [],
        "type": "override_agent",
        "position": {
          "x": -277.5918953571314,
          "y": -775.2663860017256
        },
        "edge_order": [
          "intro_to_event"
        ],
        "label": "Intro / Orient",
        "auto_advance_after_first_response": false
      },
      "event_node": {
        "conversation_config": {
          "turn": {
            "turn_eagerness": "patient",
            "spelling_patience": null,
            "speculative_turn": false
          },
          "tts": {},
          "conversation": {
            "client_events": null
          },
          "agent": {
            "prompt": {
              "built_in_tools": {}
            }
          }
        },
        "additional_prompt": "STAGE: Identify the disturbing event.\n\nAsk: 'What memory or experience would you like to work through with EMDR?' Listen. If they give a vague or broad answer (e.g. 'my childhood', 'the war'), gently narrow: 'Is there a specific incident or moment that comes to mind first?'\n\nDo not ask for graphic details at this stage. You only need to know enough to anchor the memory — a few words is plenty.\n\nIf the user is not sure what event to pick, advise them to pick the one that affects them the most, but explain that they don't need to worry about getting it perfectly right, as we just want a starting point for the processing sessions.\n\nAdvance as soon as the client has named a specific event/incident.",
        "additional_knowledge_base": [],
        "additional_tool_ids": [],
        "type": "override_agent",
        "position": {
          "x": -277.70039847559997,
          "y": -603.3031441445781
        },
        "edge_order": [
          "event_to_image",
          "edge_01ksfvf3rbeh0v7kweeyy1p2cq"
        ],
        "label": "Identify Event",
        "auto_advance_after_first_response": false
      },
      "image_node": {
        "conversation_config": {
          "turn": {
